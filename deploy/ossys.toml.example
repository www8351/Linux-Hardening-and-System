# ossys endpoint configuration — example
#
# Install location decides which automation path picks it up:
#
#   /etc/ossys/ossys.toml              → the PRIVILEGED path (root systemd timer / root cron)
#   ~/.config/ossys/ossys.toml         → the UNPRIVILEGED path (systemctl --user / user cron)
#
# Both can coexist on one endpoint. The same command line resolves to different policy
# depending on who runs it, which is the point — the timer does not need to know.
#
# Discovery order (first hit wins):
#   1. --config PATH   2. $OSSYS_CONFIG   3. ./ossys.toml
#   4. ~/.config/ossys/ossys.toml        5. /etc/ossys/ossys.toml

[defaults]
# auto | root | sudo | user
#   auto  — detect: euid 0 → root; else probe `sudo -n true`; else user
#   root  — assert we are euid 0, fail loudly if not
#   sudo  — assert passwordless sudo works, fail loudly if not
#   user  — never attempt elevation; privileged commands exit 20
#
# Forcing a mode is preferred for scheduled jobs: it turns "silently degraded to
# unprivileged and did nothing" into a loud, diagnosable failure.
mode = "auto"

# Directories output files may be written into. This is the containment list that closes
# OSSYS-SEC-001/-002 (arbitrary file write via --out). Keep it as narrow as the workload
# allows; "." means the working directory only.
allowed_roots = ["."]

# Seconds before an external command is killed. Bounds every subprocess call so a stalled
# sudo cannot hang a timer indefinitely (OSSYS-SEC-006).
timeout = 30

# Emit JSON on stdout by default. Recommended for anything scheduled — the log becomes
# structured and greppable by field instead of by regex.
json = false

# Global dry-run. Useful for staging a new profile across a fleet before arming it.
dry_run = false

# Extra binaries `ossys check` must find on this endpoint, beyond the built-in set.
require_tools = []

[defaults.mcp]
# The MCP tool server (`ossys-mcp`), which exposes ossys operations to a language model.
# Only affects that binary -- the CLI is unaffected by everything in this table.
#
# READ THIS BEFORE WIDENING IT. An MCP server hands tool invocation to a model: whatever is
# exposed can be called on the model's initiative, with arguments the model chose, in
# response to text that may have come from anywhere -- a file it read, a log line, a web
# page. Treat this list the way you would treat a sudoers entry.
enabled = true

# Tools exposed BEYOND the always-available read-only set (check, plugins, version, count,
# cubes). Empty means read-only only, which is the default and the right answer for most
# endpoints.
#
#   expose = ["archive"]            # lets a model write .tgz files inside allowed_roots
#   expose = ["archive", "details"] # ...and write text files there
expose = []

# SECOND, independent switch required before `useradd` is exposed. Listing it in `expose` is
# not enough on its own. Two opt-ins, because "let the model make backups" must never
# silently also mean "let the model create root-capable users".
#
# If you set this true AND run ossys-mcp as root, a prompt-injected model can create system
# accounts. No in-process validation prevents that; it is a deployment decision.
allow_privileged = false

[defaults.plugins]
# Entry-point plugins (group "ossys.plugins") attach new admin domains as separate packages.
# Discovery means IMPORTING third-party code -- in a root process on the privileged path.
enabled = true

# Which plugins this host may load, by name. EMPTY MEANS ALLOW ALL: fine for a workstation,
# wrong for a privileged fleet host, where any package installed into the venv could add
# root-run subcommands. Pin it on servers -- see the server profile below.
#
# `ossys plugins` lists what is installed and which distribution each came from.
allowlist = []

[defaults.webhook]
# Optional failure notification. Empty URL disables it entirely — no network traffic and no
# DNS lookup happen when this is unset.
#
# Fires only on real failures: exit 0 (success) and exit 40 (idempotent no-op) never notify,
# so a healthy scheduled job stays silent. Delivery failures never change the exit code —
# a dead collector cannot turn a validation error into something else.
url = ""
on_failure = true

# Hard bound on the POST. Alerting must not stall the run it is reporting on.
timeout = 5

# https is required. Set true only for a plaintext internal collector you accept the risk of.
allow_http = false

# `detail` usually carries an external command's stderr, which can contain usernames, paths
# and host layout. Off by default — turning it on means that data leaves the host.
include_detail = false

# NAME of an environment variable holding the bearer token — not the token itself. This file
# is mode 0644 and readable by every local user; the secret belongs in the unit's
# EnvironmentFile (systemd) or the cron job's environment.
#
#   systemd:  EnvironmentFile=/etc/ossys/webhook.env   (chmod 0600, root:root)
#   contents: OSSYS_WEBHOOK_TOKEN=...
token_env = ""


# ---------------------------------------------------------------------------------------
# Profiles overlay [defaults]. Select with --profile NAME, $OSSYS_PROFILE, or automatically
# by hostname glob — which is what makes one file deployable unchanged across a fleet.
# ---------------------------------------------------------------------------------------

[profile.workstation]
# The unprivileged path: developer laptops and desktops. No elevation, ever.
hosts = ["dev-*", "*-laptop", "ws-*"]
mode = "user"
allowed_roots = ["~/ossys"]
json = false

[profile.server]
# The privileged path: managed servers running the root system timer.
hosts = ["srv-*", "app-*", "*.prod.internal"]
mode = "sudo"
allowed_roots = ["/var/lib/ossys", "/tmp/ossys"]
timeout = 60
json = true
require_tools = ["useradd", "usermod", "tar"]

[profile.server.mcp]
# Servers expose no MCP surface at all: they are unattended, and nothing there should be
# waiting on a language model to call it.
enabled = false

[profile.server.plugins]
# Privileged endpoints pin the list. A package landing in the venv -- pulled in as a
# transitive dependency, say -- cannot then mount a subcommand that runs as root.
allowlist = ["backups"]

[profile.server.webhook]
# Servers report failures to the internal collector; workstations stay silent.
url = "https://ossys-collector.prod.internal/hook"
token_env = "OSSYS_WEBHOOK_TOKEN"

[profile.container]
# Minimal images already run as root, so sudo is absent and irrelevant.
hosts = ["*-ci", "runner-*"]
mode = "root"
allowed_roots = ["/var/lib/ossys"]
json = true

[profile.default]
# Fallback when no hostname glob matches and no --profile was given.
mode = "user"
allowed_roots = ["."]
